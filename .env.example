# Secret pour les appels planifiés (ex. GitHub Actions) et manuels : Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Resend — domaine d’expéditeur vérifié
RESEND_API_KEY=
RESEND_FROM=alerts@votredomaine.com
ALERT_EMAIL=vous@example.com

# Optionnel : montant en EUR pour la cotation catalogue (défaut 100)
# WU_QUOTE_EUR_AMOUNT=100

# Optionnel : corridor (défaut Espagne → Argentine)
# WU_SEND_COUNTRY_CODE=ES
# WU_RECEIVE_COUNTRY_CODE=AR
# WU_RECEIVE_CURRENCY_CODE=ARS
# WU_LANGUAGE_CODE=es

# Optionnel : routeur WU
# WU_ROUTER_URL=https://www.westernunion.com/router/
# WU_ACCESS_CODE=
